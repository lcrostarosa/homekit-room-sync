# HomeKit Room Sync - Deployment Configuration
#
# Copy this file to .env and customize for your setup:
#   cp env.example .env
#
# All values are optional and have sensible defaults.

# Home Assistant server IP address or hostname
# Examples:
#   HA_HOST=192.168.1.100
#   HA_HOST=homeassistant.local
#   HA_HOST=ha.mydomain.com
HA_HOST=

# SSH user for connecting to the server
# Default: root (common for HAOS)
# Use 'homeassistant' for some installations
HA_USER=root

# SSH port
# Default: 22
# Some setups use custom ports like 22222
HA_SSH_PORT=22

# Path to Home Assistant config directory
# Default: /config (standard for HAOS/Docker)
# Other common paths:
#   /home/homeassistant/.homeassistant (venv install)
#   /usr/share/hassio/homeassistant (Supervised)
HA_CONFIG_PATH=/config

# Automatically restart Home Assistant after deployment
# Set to 'true' to enable
# Default: false
HA_RESTART=false

# Docker container name for Home Assistant (if running in Docker)
# Default: homeassistant
# Common alternatives: hassio, home-assistant
HA_CONTAINER_NAME=homeassistant
